{
  "datasets": [
    {
      "name": "ds_orders",
      "displayName": "Orders",
      "queryLines": [
        "SELECT order_id, user_id, total_amount, status, order_date FROM {{CATALOG}}.{{SCHEMA}}.fact_orders "
      ]
    },
    {
      "name": "ds_order_items",
      "displayName": "Order Items",
      "queryLines": [
        "SELECT order_id, user_id, order_date, product_name, category, material, quantity, unit_price, line_total FROM {{CATALOG}}.{{SCHEMA}}.fact_order_items WHERE category IS NOT NULL "
      ]
    },
    {
      "name": "ds_gold_prices",
      "displayName": "Gold Prices",
      "queryLines": [
        "SELECT price_date, MAX(CAST(price_gram_24k AS DOUBLE)) as gold_24k, MAX(CAST(price_gram_22k AS DOUBLE)) as gold_22k, MAX(CAST(pct_change_24k AS DOUBLE)) as pct_change FROM {{CATALOG}}.{{SCHEMA}}.fact_metal_prices WHERE metal = 'Gold' GROUP BY price_date "
      ]
    },
    {
      "name": "ds_gold_vs_sales",
      "displayName": "Gold vs Sales",
      "queryLines": [
        "SELECT g.price_date, g.gold_24k, COALESCE(o.revenue, 0) as revenue, COALESCE(o.orders, 0) as orders FROM (SELECT price_date, MAX(CAST(price_gram_24k AS DOUBLE)) as gold_24k FROM {{CATALOG}}.{{SCHEMA}}.fact_metal_prices WHERE metal = 'Gold' GROUP BY price_date) g LEFT JOIN (SELECT order_date, SUM(total_amount) as revenue, COUNT(*) as orders FROM {{CATALOG}}.{{SCHEMA}}.fact_orders GROUP BY order_date) o ON g.price_date = o.order_date "
      ]
    },
    {
      "name": "ds_customers",
      "displayName": "Customer Lifetime Value",
      "queryLines": [
        "SELECT u.first_name || ' ' || u.last_name as customer_name, COUNT(DISTINCT o.order_id) as total_orders, SUM(o.total_amount) as lifetime_value FROM {{CATALOG}}.{{SCHEMA}}.dim_users u JOIN {{CATALOG}}.{{SCHEMA}}.fact_orders o ON u.user_id = o.user_id GROUP BY 1 ORDER BY lifetime_value DESC LIMIT 15 "
      ]
    },
    {
      "name": "ds_nudges",
      "displayName": "Nudge Effectiveness",
      "queryLines": [
        "SELECT nudge_type, COUNT(*) as total_nudges, SUM(CASE WHEN is_redeemed THEN 1 ELSE 0 END) as redeemed, SUM(CASE WHEN is_dismissed THEN 1 ELSE 0 END) as dismissed FROM {{CATALOG}}.{{SCHEMA}}.fact_nudges GROUP BY nudge_type "
      ]
    },
    {
      "name": "ds_wishlists",
      "displayName": "Wishlists by Category",
      "queryLines": [
        "SELECT category, COUNT(DISTINCT user_id) as wishlist_users, SUM(price_inr) as wishlist_value FROM {{CATALOG}}.{{SCHEMA}}.fact_wishlists WHERE category IS NOT NULL GROUP BY category "
      ]
    }
  ],
