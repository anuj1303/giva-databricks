{
  "name": "[GIVA] Metals Refresh Pipeline",
  "tags": { "demo": "giva", "component": "pricing" },
  "max_concurrent_runs": 1,
  "schedule": {
    "quartz_cron_expression": "0 31 3,10 * * ?",
    "timezone_id": "UTC",
    "pause_status": "PAUSED"
  },
  "tasks": [
    {
      "task_key": "refresh_metal_prices",
